    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "用户转化漏斗：注册 -> 完成画像 -> 首次 AI 对话 -> 首次试衣 -> 首次购买",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.2 }
            ]
          },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "注册" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "完成画像" }, "properties": [{ "id": "color", "value": { "fixedColor": "super-light-blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "首次 AI 对话" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "首次试衣" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "首次购买" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "valueMode": "text"
      },
      "targets": [
        {
          "expr": "sum(increase(user_registrations_total[24h]))",
          "legendFormat": "注册",
          "refId": "A"
        },
        {
          "expr": "sum(increase(style_profiles_created_total[24h]))",
          "legendFormat": "完成画像",
          "refId": "B"
        },
        {
          "expr": "sum(increase(ai_stylist_conversations_total[24h]))",
          "legendFormat": "首次 AI 对话",
          "refId": "C"
        },
        {
          "expr": "sum(increase(try_on_requests_total[24h]))",
          "legendFormat": "首次试衣",
          "refId": "D"
        },
        {
          "expr": "sum(increase(orders_created_total{status=\"completed\"}[24h]))",
          "legendFormat": "首次购买",
          "refId": "E"
        }
      ],
      "title": "用户转化漏斗 (24h)",
      "type": "bargauge"
    },
