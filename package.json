{
  "name": "xuno",
  "version": "1.0.0",
  "private": true,
  "description": "寻裳 - 智能私人形象定制与服装设计助手平台 (移动端)",
  "scripts": {
    "dev": "pnpm --filter @xuno/backend dev",
    "dev:backend": "pnpm --filter @xuno/backend dev",
    "dev:mobile": "pnpm --filter @xuno/mobile dev",
    "dev:admin": "pnpm --filter @xuno/admin dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "audit:file-matrix": "node scripts/audit/generate-file-review-matrix.mjs",
    "db:generate": "pnpm --filter @xuno/backend db:generate",
    "db:push": "pnpm --filter @xuno/backend db:push",
    "db:studio": "pnpm --filter @xuno/backend db:studio",
    "postinstall": "echo skip"
  },
  "devDependencies": {
    "@react-native/codegen": "^0.84.1",
    "concurrently": "^9.2.1",
    "expo-modules-autolinking": "~55.0.11",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "18.2.45",
      "@types/react-dom": "18.2.18",
      "multer": ">=2.1.1",
      "tar": ">=7.5.10",
      "nodemailer": ">=7.0.7",
      "lodash": ">=4.17.23",
      "js-yaml": ">=4.1.1",
      "form-data": ">=4.0.4",
      "glob": ">=10.5.0",
      "postcss": ">=8.4.35",
      "cookie@<0.7.0": ">=0.7.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "@tootallnate/once@<3.0.1": ">=3.0.1",
      "fast-xml-parser@>=4.0.0-beta.3 <=5.5.6": ">=5.5.7",
      "fast-xml-parser@>=4.0.0-beta.3 <=5.5.5": ">=5.5.6"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "dependencies": {
    "@babel/template": "^7.28.6",
    "universalify": "^2.0.1"
  }
}
