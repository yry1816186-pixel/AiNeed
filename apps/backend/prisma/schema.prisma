enum ConsultantStatus {
  pending
  active
  suspended
  inactive
}

model ConsultantProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  studioName         String
  specialties        Json
  yearsOfExperience  Int
  certifications     Json
  portfolioCases     Json
  rating             Decimal  @db.Decimal(2, 1) @default(0)
  reviewCount        Int      @default(0)
  bio                String?  @db.Text
  avatar             String?
  location           String?  @db.Text
  responseTimeAvg    Int?
  status             ConsultantStatus @default(pending)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings      ServiceBooking[]
  chatRooms     ChatRoom[]
  reviews       ConsultantReview[]
  availabilities ConsultantAvailability[]
  earnings      ConsultantEarning[]
  withdrawals   ConsultantWithdrawal[]

  @@index([userId])
  @@index([status])
  @@index([status, rating])
  @@index([rating(sort: Desc)])
  @@index([location])
}

enum ServiceType {
  styling_consultation
  wardrobe_audit
  shopping_companion
  color_analysis
  special_event
}

enum BookingStatus {
  pending
  confirmed
  in_progress
  completed
  cancelled
  no_show
}

model ServiceBooking {
  id            String   @id @default(uuid())
  userId        String
  consultantId  String

  serviceType       ServiceType
  scheduledAt       DateTime
  durationMinutes   Int      @default(60)
  status            BookingStatus @default(pending)
  notes             String?  @db.Text
  cancelReason      String?
  price             Decimal  @db.Decimal(10, 2)
  currency          String   @default("CNY")
  depositAmount       Decimal?  @db.Decimal(10, 2)
  finalPaymentAmount  Decimal?  @db.Decimal(10, 2)
  platformFee         Decimal?  @db.Decimal(10, 2) @default(0)
  consultantPayout    Decimal?  @db.Decimal(10, 2) @default(0)
  depositPaidAt       DateTime?
  finalPaidAt         DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  consultant ConsultantProfile @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  review     ConsultantReview?
  earning    ConsultantEarning?

  @@index([userId])
  @@index([consultantId])
  @@index([status])
  @@index([scheduledAt])
  @@index([userId, status])
  @@index([consultantId, status])
  @@index([consultantId, scheduledAt])
  @@index([userId, createdAt])
}

enum SenderType {
  user
  consultant
}

enum MessageType {
  text
  image
  file
  system
  proposal
}

model ChatRoom {
  id                String   @id @default(uuid())
  userId            String
  consultantId      String

  lastMessageAt     DateTime?
  lastMessagePreview String?
  isActive          Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  consultant ConsultantProfile @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  messages   ChatMessage[]

  @@index([consultantId])
  @@index([userId, consultantId])
  @@index([lastMessageAt])
  @@index([userId, isActive])
  @@index([consultantId, isActive])
}

model ChatMessage {
  id          String   @id @default(uuid())
  roomId      String
  senderId    String
  senderType  SenderType
  content     String   @db.Text
  messageType MessageType @default(text)
  imageUrl    String?
  fileUrl     String?
  isRead      Boolean  @default(false)
  readAt      DateTime?

  createdAt   DateTime @default(now())

  room        ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([roomId, createdAt])
  @@index([senderId])
  @@index([roomId, isRead])
  @@index([senderId, isRead])
}

// ==================== 顾问评价 & 可用性 & 收益 & 提现 ====================

enum EarningStatus {
  pending
  settled
  failed
}

enum WithdrawalStatus {
  pending
  processing
  completed
  rejected
}

model ConsultantReview {
  id            String   @id @default(uuid())
  bookingId     String   @unique
  userId        String
  consultantId  String

  rating        Int      // 1-5
  content       String?  @db.Text
  tags          Json     // string[]
  beforeImages  Json     // string[]
  afterImages   Json     // string[]
  isAnonymous   Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  consultant    ConsultantProfile @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  booking       ServiceBooking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([consultantId])
  @@index([userId])
  @@index([consultantId, rating])
  @@index([createdAt])
}

model ConsultantAvailability {
  id            String   @id @default(uuid())
  consultantId  String
  dayOfWeek     Int      // 0=周日, 1=周一, ..., 6=周六
  startTime     String   // "09:00"
  endTime       String   // "18:00"
  slotDuration  Int      @default(60) // 每个时段时长(分钟)
  isAvailable   Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  consultant    ConsultantProfile @relation(fields: [consultantId], references: [id], onDelete: Cascade)

  @@index([consultantId])
  @@index([consultantId, dayOfWeek])
  @@unique([consultantId, dayOfWeek, startTime])
}

model ConsultantEarning {
  id              String   @id @default(uuid())
  consultantId    String
  bookingId       String   @unique
  userId          String
  amount          Decimal  @db.Decimal(10, 2)
  platformFee     Decimal  @db.Decimal(10, 2)
  netAmount       Decimal  @db.Decimal(10, 2)
  status          EarningStatus @default(pending)
  settlementDate  DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  consultant      ConsultantProfile @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  booking         ServiceBooking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([consultantId])
  @@index([status])
  @@index([consultantId, status])
}

model ConsultantWithdrawal {
  id              String   @id @default(uuid())
  consultantId    String
  userId          String
  amount          Decimal  @db.Decimal(10, 2)
  status          WithdrawalStatus @default(pending)
  bankName        String?
  bankAccount     String?
  accountHolder   String?
  rejectedReason  String?
  processedAt     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  consultant      ConsultantProfile @relation(fields: [consultantId], references: [id], onDelete: Cascade)

  @@index([consultantId])
  @@index([status])
  @@index([consultantId, status])
}

// ==================== 灵感衣橱分类系统 ====================

enum CollectionItemType {
  post
  outfit
  try_on
}

model WardrobeCollection {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  icon        String?
  coverImage  String?
  sortOrder   Int      @default(0)
  isDefault   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       WardrobeCollectionItem[]

  @@index([userId])
  @@index([userId, sortOrder])
  @@index([userId, isDefault])
}

model WardrobeCollectionItem {
  id           String             @id @default(uuid())
  collectionId String
  collection   WardrobeCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  userId       String
  itemType     CollectionItemType
  itemId       String
  sortOrder    Int                @default(0)

  createdAt    DateTime           @default(now())

  @@unique([collectionId, itemType, itemId])
  @@index([collectionId])
  @@index([collectionId, sortOrder])
  @@index([itemType, itemId])
  @@index([userId])
}

// ==================== 推荐引擎缓存系统 ====================

model RecommendationCache {
  id          String   @id @default(cuid())
  userId      String
  category    String
  subCategory String?
  results     Json
  version     String   @default("v1")
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, subCategory, version])
  @@index([userId, category, expiresAt])
  @@map("recommendation_caches")
}

model KnowledgeGraphEntity {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  syncedAt    DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([entityType, entityId])
  @@index([entityType])
  @@map("knowledge_graph_entities")
}

// ==================== Feature Flag 系统 ====================

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  type        String   @default("boolean")
  value       Json     @default("{}")
  enabled     Boolean  @default(true)
  rules       Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  evaluations FeatureFlagEvaluation[]

  @@index([key])
  @@index([enabled])
  @@index([type])
  @@map("feature_flags")
}

model FeatureFlagEvaluation {
  id        String    @id @default(uuid())
  flagId    String
  flag      FeatureFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)
  userId    String?
  variant   String?
  result    Boolean   @default(false)
  attributes Json?
  evaluatedAt DateTime @default(now())

  @@index([flagId])
  @@index([userId])
  @@index([evaluatedAt])
  @@map("feature_flag_evaluations")
}

// ==================== 社区扩展：收藏/举报/博主商品/审核 ====================

model PostBookmark {
  id            String   @id @default(cuid())
  userId        String
  postId        String
  collectionId  String?
  createdAt     DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  post          CommunityPost  @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}

model ContentReport {
  id          String   @id @default(cuid())
  reporterId  String
  contentType String
  contentId   String
  reason      String
  status      String   @default("pending")
  reviewedBy  String?
  reviewNote  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reporter    User            @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: Cascade)
  post        CommunityPost?  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([reporterId, contentType, contentId])
  @@index([contentType, contentId])
  @@index([status])
}

model BloggerProduct {
  id            String   @id @default(cuid())
  bloggerId     String
  type          String
  title         String
  description   String?
  price         Decimal  @db.Decimal(10, 2)
  images        String[]
  relatedItemId String?
  status        String   @default("active")
  salesCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  blogger       User     @relation(fields: [bloggerId], references: [id], onDelete: Cascade)

  @@index([bloggerId])
  @@index([status])
}

model ContentModerationLog {
  id          String   @id @default(cuid())
  contentType String
  contentId   String
  action      String
  reason      String?
  moderatorId String?
  createdAt   DateTime @default(now())

  post        CommunityPost? @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentType, contentId])
}

// ==================== Phase 5: 电商闭环 ====================

model Coupon {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  type        CouponType
  value       Decimal  @db.Decimal(10, 2)
  minOrderAmount Decimal @db.Decimal(10, 2) @default(0)
  maxDiscount Decimal? @db.Decimal(10, 2)
  validFrom   DateTime
  validUntil  DateTime
  usageLimit  Int?     // null = unlimited
  usedCount   Int      @default(0)
  perUserLimit Int     @default(1)
  applicableCategories String[] @default([])
  applicableBrandIds   String[] @default([])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userCoupons UserCoupon[]

  @@index([code])
  @@index([isActive, validFrom, validUntil])
}

model UserCoupon {
  id        String   @id @default(uuid())
  userId    String
  couponId  String
  status    UserCouponStatus
  usedAt    DateTime?
  orderId   String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon    Coupon   @relation(fields: [couponId], references: [id])

  @@unique([userId, couponId])
  @@index([userId, status])
}

model StockNotification {
  id        String   @id @default(uuid())
  userId    String
  itemId    String
  color     String?
  size      String?
  status    StockNotificationStatus
  notifiedAt DateTime?
  createdAt DateTime @default(now())

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  item      ClothingItem  @relation(fields: [itemId], references: [id])

  @@unique([userId, itemId, color, size])
  @@index([itemId, status])
  @@index([userId, status])
}

model RefundRequest {
  id              String   @id @default(uuid())
  orderId         String
  userId          String
  type            RefundType
  reason          String
  description     String?
  images          String[] @default([])
  amount          Decimal  @db.Decimal(10, 2)
  status          RefundRequestStatus
  trackingNumber  String?
  adminNote       String?
  processedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  order           Order    @relation(fields: [orderId], references: [id])
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([userId, status])
}

