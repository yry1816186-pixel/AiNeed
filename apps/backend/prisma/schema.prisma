enum PaymentRecordStatus {
  pending
  paid
  failed
  refunded
  cancelled
  closed
}

model RefundRecord {
  id              String    @id @default(uuid())
  paymentRecordId String

  amount          Decimal   @db.Decimal(10, 2)
  reason          String?

  status          RefundRecordStatus @default(processing)
  refundNo        String?   @unique // 第三方退款号

