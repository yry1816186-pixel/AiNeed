generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  emailHash String?  @unique
  phone     String?  @unique // @encrypted: PII - encrypt in Service layer before storage
  wechatOpenId String? @unique
  wechatUnionId String? @unique
  authProvider AuthProvider @default(email)
  password  String // @encrypted: Hash with bcrypt, never store plain text
  nickname  String?
  avatar    String?
  gender    Gender?
  birthDate DateTime?
  isActive  Boolean  @default(true)

  // P1-Data-2: 软删除字段（GDPR/PIPL合规）
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  deletedReason String?

  followerCount  Int @default(0)
  followingCount Int @default(0)
  isVerified     Boolean @default(false)
  bio            String? @db.Text

  // Per-user encryption key fields
  encryptionKeySalt String?
  encryptedDek      String?
  keyVersion        Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile     UserProfile?
  photos      UserPhoto[]
  tryOns      VirtualTryOn[]
  favorites   Favorite[]
  customizations CustomizationRequest[]
  customizationDesigns CustomizationDesign[]
  cartItems   CartItem[]
  orders      Order[]
  addresses   UserAddress[]
  behaviors   UserBehavior[]
  behaviorEvents     UserBehaviorEvent[]
  recommendationCaches RecommendationCache[]
  userClothings UserClothing[]
  outfits    Outfit[]
  aiStylistSessions AiStylistSession[]
  userDecisions UserDecision[]
  styleProfiles     StyleProfile[]
  rankingFeedback   RankingFeedback[]
  styleRecommendations StyleRecommendation[]
  notifications     Notification[]
  paymentOrders     PaymentOrder[]
  userSubscriptions UserSubscription[]

  posts         CommunityPost[] @relation("AuthorPosts")
  postLikes     PostLike[]
  postComments  PostComment[]
  followers     UserFollow[]  @relation("UserFollowers")
  following     UserFollow[]  @relation("UserFollowing")
  refreshTokens RefreshToken[]
  wardrobeCollections WardrobeCollection[]
  quizAnswers   QuizAnswer[]
  quizResults   StyleQuizResult[]

  bloggerLevel  String?
  bloggerScore  Float?    @default(0)
  bloggerBadge  String?
  bookmarks     PostBookmark[]
  bloggerProducts BloggerProduct[]
  contentReports ContentReport[] @relation("ReporterReports")

  // Phase 8: 顾问系统关联
  consultantProfile ConsultantProfile?
  serviceBookings   ServiceBooking[]
  chatRooms         ChatRoom[]
  consultantReviews   ConsultantReview[]
  consultantEarnings  ConsultantEarning[]
  consultantWithdrawals ConsultantWithdrawal[]

  consents             UserConsent[]
  notificationSetting  UserNotificationSetting?
  pushDeviceTokens     PushDeviceToken[]

  // Phase 5: E-commerce relations
  userCoupons          UserCoupon[]
  stockNotifications   StockNotification[]
  refundRequests       RefundRequest[]

  @@index([email])
  @@index([phone])
  @@index([isActive])
  @@index([createdAt(sort: Desc)])
}

// Phase 5: E-commerce enums
enum CouponType {
  PERCENTAGE
  FIXED
  SHIPPING
}

enum UserCouponStatus {
  AVAILABLE
  USED
  EXPIRED
}

enum StockNotificationStatus {
  PENDING
  NOTIFIED
  CANCELLED
}

enum RefundType {
  REFUND_ONLY
  RETURN_REFUND
}

enum RefundRequestStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSING
  COMPLETED
}

enum Gender {
  male
  female
  other
}

enum AuthProvider {
  email
  phone
  wechat
}

model UserProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  bodyType      BodyType?
  skinTone      SkinTone?
  faceShape     FaceShape?
            colorSeason   ColorSeason?

  height    Float?
  weight    Float?
  shoulder  Float?
  bust      Float?
  waist     Float?
  hip       Float?
  inseam    Float?

  stylePreferences Json?
  colorPreferences  Json?

  priceRangeMin  Float?
  priceRangeMax  Float?

  onboardingStep        OnboardingStep @default(BASIC_INFO)
  onboardingCompletedAt DateTime?
  skippedOnboardingSteps String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([bodyType])
  @@index([skinTone])
  @@index([colorSeason])
}

model UserBehavior {
  id          String   @id @default(uuid())
  userId      String
  itemId      String?
  type        String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([userId, type, createdAt])
  @@index([itemId])
  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model RankingFeedback {
  id          String   @id @default(uuid())
  userId      String
  itemId      String
  action      String
  weight      Decimal  @db.Decimal(5, 4)
  createdAt   DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  item        ClothingItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([itemId])
  @@index([userId, itemId])
  @@index([createdAt(sort: Desc)])
  @@index([userId, action])
  @@index([itemId, action])
}

model SystemConfig {
  key         String   @id
  value       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StyleProfile {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  occasion    String
  description String
  keywords    String[]
  palette     String[]
  confidence  Int      @default(70)
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([occasion])
  @@index([userId, isDefault])
  @@index([userId, isActive])
}

enum OnboardingStep {
  BASIC_INFO
  PHOTO
  STYLE_TEST
  COMPLETED
}

enum BodyType {
  rectangle
  triangle
  inverted_triangle
  hourglass
  oval
}

enum SkinTone {
  fair
  light
  medium
  olive
  tan
  dark
}

enum FaceShape {
  oval
  round
  square
  heart
  oblong
  diamond
}

enum ColorSeason {
  spring_warm
  spring_light
  summer_cool
  summer_light
  autumn_warm
  autumn_deep
  winter_cool
  winter_deep
}

model UserPhoto {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type          PhotoType
  url           String
  thumbnailUrl  String?
  originalName  String?
  mimeType      String?
  size          Int?
  
  analysisResult    Json?
  analysisStatus    AnalysisStatus @default(pending)
  analyzedAt        DateTime?
  
  createdAt DateTime @default(now())

  tryOns    VirtualTryOn[]

  @@index([userId])
  @@index([type])
  @@index([analysisStatus])
  @@index([userId, analysisStatus])
}

enum PhotoType {
  front
  side
  full_body
  half_body
  face
}

enum AnalysisStatus {
  pending
  processing
  completed
  failed
}

model Brand {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  logo        String?
  description String?
  website     String?
  categories  String[]
  priceRange  PriceRange @default(mid_range)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 商家信息
  contactEmail   String? // @encrypted: PII - consider encrypting for compliance
  contactPhone   String? // @encrypted: PII - consider encrypting for compliance
  businessLicense String?
  verified        Boolean  @default(false)
  verifiedAt      DateTime?

  // 结算信息
  bankName       String?
  bankAccount    String?
  commissionRate Decimal @default(0.10) @db.Decimal(5, 4)

  products    ClothingItem[]
  merchants   BrandMerchant[]
  settlements BrandSettlement[]

  @@index([slug])
  @@index([verified])
}

enum PriceRange {
  budget
  mid_range
  premium
  luxury
}

model ClothingItem {
  id          String   @id @default(uuid())
  brandId     String?
  brand       Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)

  name        String
  description String?
  sku         String?  @unique

  category    ClothingCategory
  subcategory String?

  colors      String[]
  sizes       String[]
  tags        String[]

  price       Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @db.Decimal(10, 2)
  currency    String   @default("CNY")

  // FIX-BL-006: 库存管理字段 (修复时间: 2026-03-19)
  stock       Int      @default(0)
  lowStockThreshold Int @default(10)

  images      String[]
  mainImage   String?

  externalUrl String?
  externalId  String?

  attributes  Json?

  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?

  viewCount   Int      @default(0)
  likeCount   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  favorites   Favorite[]
  tryOns      VirtualTryOn[]
  salesStats  ProductSalesStats[]
  cartItems   CartItem[]
  orderItems  OrderItem[]
  postItems   CommunityPostItem[]
  rankingFeedback RankingFeedback[]
  stockNotifications StockNotification[]

  // 核心业务索引（精简至15个，优化写入性能）
  // P1-Data-1: 移除冗余索引 [category], [viewCount], [likeCount], [isDeleted]
  // 保留原则：外键优先 > 复合索引 > 高频单列 > 排序索引
  @@index([brandId])                                      // 外键：品牌关联查询
  @@index([category, isActive])                           // 核心：分类列表页（覆盖[category]单列）
  @@index([price])                                        // 核心：价格范围筛选
  @@index([createdAt(sort: Desc)])                        // 核心：默认排序
  @@index([name])                                         // 核心：名称模糊搜索
  @@index([isActive, isFeatured])                         // 业务：精选商品展示
  @@index([isActive, createdAt(sort: Desc)])              // 业务：活跃商品时间线
  @@index([isActive, price])                              // 业务：活跃商品价格排序
  @@index([isActive, viewCount(sort: Desc)])              // 业务：热门商品排行（覆盖单列viewCount）
  @@index([isActive, likeCount(sort: Desc)])              // 业务：最受欢迎排行（覆盖单列likeCount）
  @@index([stock])                                        // 业务：低库存预警
  @@index([isDeleted, isActive])                          // 合规：软删除过滤（覆盖单列isDeleted）
}

enum ClothingCategory {
  tops
  bottoms
  dresses
  outerwear
  footwear
  accessories
  activewear
  swimwear
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  itemId    String
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item      ClothingItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@unique([userId, itemId])
  @@index([userId])
  @@index([itemId])
  @@index([createdAt(sort: Desc)])
}

model VirtualTryOn {
  id        String   @id @default(uuid())
  userId    String
  photoId   String
  itemId    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  photo     UserPhoto @relation(fields: [photoId], references: [id], onDelete: Cascade)
  item      ClothingItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  resultImageUrl String?
  watermarkedImageUrl String?
  status        TryOnStatus @default(pending)
  errorMessage  String?
  provider      String?
  processingTime Float?
  confidence    Float?
  category      String?
  scene         String?
  retryCount    Int        @default(0)
  parentTryOnId String?

  parentTryOn   VirtualTryOn?  @relation("TryOnRetry", fields: [parentTryOnId], references: [id])
  retries       VirtualTryOn[] @relation("TryOnRetry")

  createdAt DateTime @default(now())
  completedAt DateTime?

  @@index([userId])
  @@index([status])
  @@index([itemId])
  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@index([photoId, status])
  @@index([userId, photoId])
  @@index([userId, photoId, itemId, status])
  @@index([category])
  @@index([parentTryOnId])
}

enum TryOnStatus {
  pending
  processing
  completed
  failed
}

model CustomizationRequest {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type            CustomizationType
  title           String?
  description     String  @db.Text
  referenceImages String[]
  preferences     Json?

  status      CustomizationStatus @default(draft)

  selectedQuoteId String?
  quotes      CustomizationQuote[]

  // Editor customization fields
  designId        String?  @unique
  design          CustomizationDesign?  @relation(fields: [designId], references: [id], onDelete: SetNull)
  templateId      String?
  template        CustomizationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  previewImageUrl String?

  // Production + fulfillment fields
  paymentId       String?
  podOrderId      String?
  trackingNumber  String?
  carrier         String?
  estimatedDeliveryDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([type])
  @@index([createdAt(sort: Desc)])
  @@index([designId])
  @@index([templateId])
}

enum CustomizationType {
  tailored
  bespoke
  alteration
  design
  pod
}

enum CustomizationStatus {
  draft
  submitted
  quoting
  confirmed
  in_progress
  shipped
  completed
  cancelled
}

enum ProductTemplateType {
  tshirt
  hat
  shoes
  bag
  phone_case
  mug
}

enum DesignLayerType {
  image
  text
  shape
}

model CustomizationQuote {
  id          String   @id @default(uuid())
  requestId   String
  request     CustomizationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  providerId     String
  providerName   String
  providerLogo   String?

  price          Decimal  @db.Decimal(10, 2)
  currency       String @default("CNY")
  estimatedDays  Int

  description    String  @db.Text
  terms          String? @db.Text

  createdAt DateTime @default(now())

  @@index([requestId])
  @@index([requestId, createdAt(sort: Desc)])
}

model CustomizationTemplate {
  id          String   @id @default(uuid())
  type        ProductTemplateType
  name        String
  description String?
  imageUrl    String
  basePrice   Decimal  @db.Decimal(10, 2)

  // Printable area bounds as percentages of canvas
  printableArea Json    // { x, y, width, height, maxWidth, maxHeight }

  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  designs    CustomizationDesign[]
  requests   CustomizationRequest[]

  @@index([type])
  @@index([isActive])
}

model CustomizationDesign {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  templateId  String
  template    CustomizationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  canvasData  Json     // Full canvas state as JSON
  previewUrl  String?  // Generated preview image URL

  layers      CustomizationDesignLayer[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  request     CustomizationRequest?

  @@index([userId])
  @@index([templateId])
  @@index([userId, createdAt(sort: Desc)])
}

model CustomizationDesignLayer {
  id        String   @id @default(uuid())
  designId  String
  design    CustomizationDesign @relation(fields: [designId], references: [id], onDelete: Cascade)

  type      DesignLayerType
  content   String   // Image URL or text content
  x         Float    @default(0)
  y         Float    @default(0)
  width     Float    @default(100)
  height    Float    @default(100)
  scale     Float    @default(1)
  rotation  Float    @default(0)
  opacity   Float    @default(1)
  zIndex    Int      @default(0)

  // Text-specific
  fontSize  Int?
  color     String?  // Hex color
  fontFamily String?

  // Image-specific
  imageUrl  String?

  // Shape-specific
  shapeType String?  // rect, circle, triangle
  fillColor String?  // Hex color
  strokeColor String?
  strokeWidth  Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([designId])
  @@index([designId, zIndex])
}

model StyleRecommendation {
  id        String   @id @default(uuid())
  userId    String

  type      RecommendationType
  items     Json
  reason    String?  @db.Text
  score     Decimal  @db.Decimal(5, 4)

  isViewed  Boolean  @default(false)
  isLiked   Boolean  @default(false)

  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([userId, type])
  @@index([userId, isViewed])
  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
  @@index([userId, type, createdAt(sort: Desc)])
}

enum RecommendationType {
  daily
  occasion
  seasonal
  trending
  business
}

model SearchHistory {
  id        String   @id @default(uuid())
  userId    String?
  sessionId String?

  query     String
  filters   Json?
  results   Int

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([sessionId, createdAt(sort: Desc)])
  @@index([query])
  @@index([userId, query])
}

model AIAnalysisCache {
  id          String   @id @default(uuid())
  imageHash   String   @unique
  analysisType String
  result      Json
  confidence  Decimal @db.Decimal(5, 4)

  hitCount    Int      @default(1)
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  @@index([imageHash])
  @@index([analysisType])
  @@index([expiresAt])
  @@index([analysisType, expiresAt])
}

// ==================== 用户行为追踪系统 ====================

model UserBehaviorEvent {
  id          String   @id @default(uuid())
  userId      String?
  sessionId   String
  anonymousId String?

  eventType   BehaviorEventType
  category    String
  action      String

  targetType  String?
  targetId    String?
  metadata    Json?

  source      String?
  referrer    String?
  deviceInfo  Json?
  location    Json?

  duration    Int?

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([eventType, createdAt])
  @@index([targetType, targetId])
  @@index([userId, eventType, createdAt(sort: Desc)])
  @@index([category, action, createdAt(sort: Desc)])
  @@index([userId, createdAt])
  @@index([targetId, action])
  @@index([userId, action, createdAt])

  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum InteractionWeight {
  view
  click
  like
  favorite
  addToCart
  purchase
  tryOn
  share
  dislike
}

enum BehaviorEventType {
  page_view
  item_view
  search
  filter
  click
  scroll
  try_on_start
  try_on_complete
  favorite
  unfavorite
  share
  add_to_cart
  remove_from_cart
  purchase
  recommendation_view
  recommendation_click
  post_create
  post_like
  post_comment
  user_follow
}

model UserPreferenceWeight {
  id          String   @id @default(uuid())
  userId      String

  category    String
  key         String
  weight      Decimal @db.Decimal(5, 4)
  source      String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, category, key])
  @@index([userId])
}

model UserSession {
  id            String   @id @default(uuid())
  userId        String?
  anonymousId   String?

  deviceType    String?
  os            String?
  browser       String?
  screenWidth   Int?

  referrer      String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?

  startedAt     DateTime @default(now())
  endedAt       DateTime?
  duration      Int?
  pageViews     Int      @default(0)

  @@index([userId])
  @@index([anonymousId])
}

model AiStylistSession {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  payload   Json
  status    String   @default("active")

  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([expiresAt])
}

model UserDecision {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId       String
  nodeId          String
  nodeType        String
  chosenOptionId  String
  rejectedOptionIds String[]
  decisionTime    Int
  timestamp       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, sessionId])
  @@index([sessionId, nodeId])
  @@index([userId, createdAt(sort: Desc)])
}

// ==================== 会员订阅系统 ====================

model MembershipPlan {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("CNY")

  features    Json

  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions UserSubscription[]

  @@index([isActive, sortOrder])
  @@index([isActive, price])
}

model UserSubscription {
  id          String   @id @default(uuid())
  userId      String
  planId      String

  status      SubscriptionStatus @default(active)

  startedAt   DateTime
  expiresAt   DateTime
  cancelledAt DateTime?

  paymentMethod String?
  autoRenew     Boolean @default(true)

  usageThisMonth Json @default("{}")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        MembershipPlan @relation(fields: [planId], references: [id])
  paymentOrders PaymentOrder[]

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, status])
  @@index([status, expiresAt])
  @@index([userId, expiresAt])
}

enum SubscriptionStatus {
  active
  expired
  cancelled
  past_due
}

model PaymentOrder {
  id            String   @id @default(uuid())
  userId        String
  subscriptionId String?

  amount        Decimal  @db.Decimal(10, 2)
  currency      String   @default("CNY")

  status        PaymentStatus @default(pending)

  paymentMethod String?
  paymentId     String?

  metadata      Json?

  paidAt        DateTime?
  refundedAt    DateTime?
  createdAt     DateTime @default(now())

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription  UserSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([paymentId])
  @@index([userId, status])
  @@index([status, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

enum PaymentStatus {
