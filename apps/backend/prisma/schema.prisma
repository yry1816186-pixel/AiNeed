model OutfitItem {
  id          String   @id @default(uuid())
  outfitId    String
  clothingId  String
  
  positionX   Float    @default(0.5)
  positionY   Float    @default(0.5)
  width       Float    @default(0.3)
  height      Float    @default(0.3)
  rotation    Float    @default(0)
  zIndex      Int      @default(0)
  
  notes       String?
  
  createdAt   DateTime @default(now())
  
  outfit      Outfit       @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  clothing    UserClothing @relation(fields: [clothingId], references: [id], onDelete: Cascade)
  
  @@index([outfitId])
  @@index([clothingId])
}

model CommunityPost {
  id          String   @id @default(uuid())
  authorId    String
  title       String
  content     String   @db.Text
  images      String[]
  tags        String[]
  category    String   @default("outfit_share")

  viewCount   Int      @default(0)
  likeCount   Int      @default(0)
  commentCount Int     @default(0)
  shareCount  Int      @default(0)

  isFeatured  Boolean  @default(false)
  isHidden    Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?

  bookmarkCount     Int      @default(0)
  hotScore          Float    @default(0)
  moderationStatus  String   @default("approved")
  reportCount       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User           @relation("AuthorPosts", fields: [authorId], references: [id], onDelete: Cascade)
  likes       PostLike[]
  comments    PostComment[]
  relatedItems CommunityPostItem[]
  bookmarks   PostBookmark[]
  moderationLogs ContentModerationLog[]
  reports     ContentReport[]

  @@index([authorId])
  @@index([category])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([authorId, isDeleted])
  @@index([category, isDeleted])
  @@index([isFeatured, isDeleted])
  @@index([likeCount(sort: Desc)])
  @@index([viewCount(sort: Desc)])
  @@index([createdAt(sort: Desc), isDeleted])
  // P1-Data-4: 拆分4列宽索引为3个窄索引（优化写入性能+提升查询灵活性）
  // 原: [isDeleted, isFeatured, likeCount, createdAt] → 维护成本高且不够灵活
  // 新: 按业务场景拆分
  @@index([isDeleted, likeCount(sort: Desc)])           // 场景1: 热门帖子排行
  @@index([isFeatured, isDeleted, createdAt(sort: Desc)]) // 场景2: 精选帖子时间线
}

model CommunityPostItem {
  id        String   @id @default(uuid())
  postId    String
  itemId    String
  createdAt DateTime @default(now())
  
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  item      ClothingItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  @@unique([postId, itemId])
  @@index([postId])
  @@index([itemId])
}

model PostLike {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      CommunityPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}

model PostComment {
  id        String   @id @default(uuid())
  authorId  String
  postId    String
  parentId  String?
  content   String   @db.Text
  images    String[]
  
  likeCount Int      @default(0)
  isDeleted Boolean  @default(false)
  deletedAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      CommunityPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent    PostComment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies   PostComment[]  @relation("CommentReplies")
  
  @@index([authorId])
  @@index([postId])
  @@index([parentId])
  @@index([postId, createdAt(sort: Desc)])
  @@index([postId, isDeleted])
}

model UserFollow {
  id           String   @id @default(uuid())
  followerId   String
  followingId  String
  createdAt    DateTime @default(now())

  follower     User  @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following    User  @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

