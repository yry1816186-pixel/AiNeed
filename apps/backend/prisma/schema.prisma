  totalSales      Decimal  @db.Decimal(12, 2)
  commission      Decimal  @db.Decimal(10, 2)
  netAmount       Decimal  @db.Decimal(12, 2)

  status      SettlementStatus @default(pending)

  paidAt      DateTime?

  createdAt   DateTime @default(now())

  @@unique([brandId, period])
  @@index([brandId])
  @@index([status])
