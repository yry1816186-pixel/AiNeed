{
  "preset": "ts-jest",
  "rootDir": ".",
  "testEnvironment": "node",
  "testMatch": ["**/*.spec.ts"],
  "moduleFileExtensions": ["ts", "js", "json"],
  "transform": {
    "^.+\\.ts$": ["ts-jest", {
      "tsconfig": {
        "noImplicitAny": false,
        "strict": false,
        "noImplicitReturns": false,
        "noUncheckedIndexedAccess": false,
        "strictNullChecks": false,
        "strictBindCallApply": false
      }
    }]
  }
}
