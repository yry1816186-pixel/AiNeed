{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": "tsconfig.json"
      }
    ]
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1"
  },
  "testTimeout": 30000,
  "verbose": true,
  "detectOpenHandles": true,
  "forceExit": true,
  "collectCoverageFrom": [
    "../src/**/*.ts",
    "!../src/main.ts",
    "!../src/**/*.module.ts",
    "!../src/**/*.dto.ts",
    "!../src/**/*.interface.ts",
    "!../src/**/*.guard.ts",
    "!../src/**/*.decorator.ts",
    "!../src/**/*.strategy.ts"
  ],
  "coverageDirectory": "../coverage/e2e",
  "coverageReporters": ["text", "lcov", "html"]
}
