# ============================================
# AiNeed Backend Environment Configuration
# SECURITY: All sensitive values must be changed for production!
# Copy this file to .env and fill in real values
# ============================================

# ===== Application =====
NODE_ENV=development
PORT=3001

# ===== Database (PostgreSQL 16) =====
# Generate strong password: openssl rand -base64 24 | tr -d '/+=' | head -c 24
DATABASE_URL="postgresql://postgres:YOUR_POSTGRES_PASSWORD@127.0.0.1:5432/stylemind?schema=public&connection_limit=5&pool_timeout=30&connect_timeout=10"

# ===== Redis 7 =====
# Generate: openssl rand -hex 32
REDIS_URL="redis://:YOUR_REDIS_PASSWORD@localhost:6379"
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# ===== JWT Authentication (512-bit) =====
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=YOUR_512_BIT_JWT_SECRET_HERE_MIN_128_CHARS
JWT_REFRESH_SECRET=YOUR_512_BIT_JWT_REFRESH_SECRET_HERE_MIN_128_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===== CSRF Protection =====
CSRF_SECRET=YOUR_CSRF_SECRET_HERE_AT_LEAST_32_CHARS

# ===== Data Encryption (AES-256-GCM) =====
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=YOUR_64_CHAR_HEX_ENCRYPTION_KEY_HERE

# ===== MinIO Object Storage =====
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=YOUR_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=YOUR_MINIO_SECRET_KEY
MINIO_BUCKET=aineed
MINIO_USE_SSL=false

# ===== AI Service URLs =====
AI_SERVICE_URL=http://localhost:8002
BODY_ANALYSIS_SERVICE_URL=http://localhost:8003

# ===== GLM-5 (ZhipuAI) LLM =====
GLM_API_KEY=YOUR_GLM_API_KEY
GLM_API_ENDPOINT=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-5

# ===== OpenAI (Optional Fallback) =====
OPENAI_API_KEY=
OPENAI_API_ENDPOINT=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ===== Circuit Breaker Configuration =====
AI_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
AI_CIRCUIT_BREAKER_SUCCESS_THRESHOLD=3
AI_CIRCUIT_BREAKER_TIMEOUT=30000
AI_CIRCUIT_BREAKER_VOLUME_THRESHOLD=10
AI_CIRCUIT_BREAKER_ERROR_THRESHOLD_PERCENTAGE=50
AI_CIRCUIT_BREAKER_RESET_TIMEOUT=30000

# ===== Payment - Alipay =====
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=
ALIPAY_SANDBOX=true

# ===== Payment - WeChat Pay =====
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_API_V3_KEY=
WECHAT_SERIAL_NO=
WECHAT_NOTIFY_URL=
WECHAT_PRIVATE_KEY=
WECHAT_CERT_PATH=

# ===== Aliyun Vision AI (Optional) =====
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_REGION=cn-shanghai

# ===== Test Account (Development Only) =====
TEST_ACCOUNT_ENABLED=true
TEST_ACCOUNT_EMAIL=test@example.com
TEST_ACCOUNT_PASSWORD=Test123456!

# ===== Monitoring =====
SENTRY_DSN=
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=YOUR_GRAFANA_PASSWORD
