# ============================================
# 寻裳 Mobile App Environment Configuration
# Copy this file to .env and fill in real values
# ============================================

# ===== Backend API =====
# Android emulator uses 10.0.2.2 to reach host localhost
# iOS simulator uses localhost directly
EXPO_PUBLIC_API_URL=http://10.0.2.2:3001/api/v1

# ===== AI Service =====
EXPO_PUBLIC_AI_SERVICE_URL=http://10.0.2.2:8002

# ===== EAS Build =====
# Create project at: https://expo.dev/
EAS_PROJECT_ID=00000000-0000-0000-0000-000000000000

# ===== Feature Flags =====
# Keep disabled in release unless each mobile flow has been audited against real data
EXPO_PUBLIC_ENABLE_UNVERIFIED_MOBILE_DEMOS=false

# ===== WeChat Login =====
# Apply at: https://open.weixin.qq.com/
EXPO_PUBLIC_WECHAT_APP_ID=
EXPO_PUBLIC_WECHAT_UNIVERSAL_LINK=

# ===== Optional AI Service Keys =====
EXPO_PUBLIC_FAL_KEY=
EXPO_PUBLIC_OPENAI_KEY=

# ===== Error Monitoring =====
# Apply at: https://sentry.io/
EXPO_PUBLIC_SENTRY_DSN=

# ===== Speech Service =====
EXPO_PUBLIC_SPEECH_API_URL=https://api.example.com/speech
EXPO_PUBLIC_SPEECH_API_KEY=
