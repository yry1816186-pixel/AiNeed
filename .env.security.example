# ============================================
# XunO Security Configuration Template
# ============================================
# This is a template for secure environment configuration.
# Copy this file to .env and fill in your secure values.
#
# IMPORTANT: Never commit .env to version control!
# ============================================

# ===== Application =====
NODE_ENV=production

# ===== Backend Service =====
BACKEND_URL=http://localhost:3001
API_URL=http://localhost:3001/api/v1

# ===== Python AI Service =====
AI_SERVICE_URL=http://localhost:8001

# ===== Database =====
# Generate a strong password:
#   Linux/Mac: openssl rand -base64 24 | tr -d '/+=' | head -c 24
#   Or use a password manager to generate a 24+ character password
POSTGRES_PASSWORD=<YOUR_SECURE_PASSWORD_HERE>
DATABASE_URL="postgresql://postgres:<YOUR_SECURE_PASSWORD_HERE>@localhost:5432/stylemind?schema=public"

# ===== Redis =====
# For production, consider adding Redis password authentication
REDIS_URL="redis://localhost:6379"

# ===== JWT Authentication =====
# Generate a 64-character secret key:
#   Linux/Mac: openssl rand -hex 32
# WARNING: This secret is used to sign JWT tokens. Keep it secure!
JWT_SECRET=<YOUR_64_CHAR_SECRET_KEY_HERE>
JWT_EXPIRES_IN=7d

# ===== MinIO Storage =====
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
# Generate credentials:
#   Access Key (8 chars): openssl rand -base64 8 | tr -d '/+=' | head -c 8
#   Secret Key (24 chars): openssl rand -base64 24 | tr -d '/+=' | head -c 24
MINIO_ACCESS_KEY=<YOUR_ACCESS_KEY_HERE>
MINIO_SECRET_KEY=<YOUR_SECRET_KEY_HERE>
MINIO_BUCKET=stylemind
MINIO_USE_SSL=false

# ===== Local AI Models =====
USE_LOCAL_MODELS=true
MODELS_DIR=C:/AiNeed/models

# ===== CLIP Model =====
CLIP_MODEL_PATH=C:/AiNeed/ml/models/clip_fashion
CLIP_MODEL_NAME=openai/clip-vit-base-patch32

# ===== YOLO Model =====
YOLO_MODEL_PATH=C:/AiNeed/yolo11n.pt

# ===== SAM Model =====
SAM_MODEL_PATH=C:/AiNeed/models/sam/sam_vit_h_4b8939.pth
SAM_ENABLED=true

# ===== GLM Virtual Try-On =====
USE_LOCAL_TRYON=false
VIRTUAL_TRYON_URL=http://localhost:8002
GLM_API_KEY=YOUR_GLM_API_KEY

# ===== SASRec Recommendations =====
USE_LOCAL_SASREC=false
SASREC_ENDPOINT=http://localhost:8002

# ===== Body Analysis =====
USE_LOCAL_BODY_ANALYSIS=true
BODY_ANALYSIS_ENDPOINT=http://localhost:8001

# ===== GPU Configuration =====
CUDA_VISIBLE_DEVICES=0

# ===== OpenAI (AI Stylist) =====
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY_HERE>
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# ===== Aliyun Vision AI (Optional) =====
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_REGION=cn-shanghai

# ===== Kolors Virtual Try-On (Optional) =====
KOLORS_API_KEY=
KOLORS_API_ENDPOINT=

# ===== Payment Configuration (Optional) =====
# Alipay
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=
ALIPAY_SANDBOX=true

# WeChat Pay
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_API_V3_KEY=
WECHAT_SERIAL_NO=
WECHAT_NOTIFY_URL=
WECHAT_PRIVATE_KEY=
WECHAT_CERT_PATH=
WECHAT_PLATFORM_CERT=

# ===== Mobile App =====
EXPO_PUBLIC_API_URL=http://10.0.2.2:3001/api/v1
EXPO_PUBLIC_AI_SERVICE_URL=http://10.0.2.2:8001

# ============================================
# Security Checklist
# ============================================
# [ ] All passwords are strong (24+ characters)
# [ ] JWT_SECRET is 64 characters
# [ ] API keys are valid and have proper scopes
# [ ] .env is in .gitignore
# [ ] No credentials in code or comments
# [ ] Run scripts/security-check.sh to verify
# ============================================
