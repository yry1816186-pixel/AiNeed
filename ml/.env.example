# ============================================
# 寻裳 ML Services Environment Configuration
# Copy this file to .env and fill in real values
# ============================================

# ===== HuggingFace Mirror (China Network) =====
HF_ENDPOINT=https://hf-mirror.com

# ===== CatVTON Virtual Try-On =====
CATVTON_REPO_PATH=/path/to/CatVTON
CATVTON_MODEL_PATH=./models/catvton
CATVTON_HOST=0.0.0.0
CATVTON_PORT=8001
CUDA_VISIBLE_DEVICES=0
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:4096

# ===== Debugging =====
DEBUG_SAVE_INTERMEDIATE=false
LOG_LEVEL=INFO

# ===== GLM API for AI Stylist =====
GLM_API_KEY=YOUR_GLM_API_KEY
GLM_API_ENDPOINT=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-5
ZHIPU_API_KEY=YOUR_ZHIPU_API_KEY

# ===== Qdrant Vector DB =====
QDRANT_URL=http://localhost:6333

# ===== Redis for Task Queue =====
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379
MAX_CONCURRENT_TASKS=3

# ===== CatVTON Endpoint (for task worker) =====
CATVTON_ENDPOINT=http://localhost:8001
