# ============================================
# 寻裳 ML Services Environment Configuration
# Copy this file to .env and fill in real values
# ============================================

# ===== HuggingFace Mirror (China Network) =====
HF_ENDPOINT=https://hf-mirror.com

# ===== GLM API for Virtual Try-On =====
GLM_API_KEY=YOUR_GLM_API_KEY
GLM_API_ENDPOINT=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-5
ZHIPU_API_KEY=YOUR_ZHIPU_API_KEY

# ===== Debugging =====
DEBUG_SAVE_INTERMEDIATE=false
LOG_LEVEL=INFO

# ===== GLM API for AI Stylist =====
GLM_API_KEY=YOUR_GLM_API_KEY
GLM_API_ENDPOINT=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-5
ZHIPU_API_KEY=YOUR_ZHIPU_API_KEY

# ===== Qdrant Vector DB =====
QDRANT_URL=http://localhost:6333

# ===== Redis for Task Queue =====
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379
MAX_CONCURRENT_TASKS=3

# ===== Virtual Try-On Service =====
VIRTUAL_TRYON_URL=http://localhost:8002
