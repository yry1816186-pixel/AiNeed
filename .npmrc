# Use a repo-local store so installs work on both Windows and WSL/Linux
store-dir=.pnpm-store

# Use the canonical npm registry to avoid mirror-specific timeouts in WSL
registry=https://registry.npmjs.org

# Use hoisted mode for React Native Metro compatibility
node-linker=hoisted
# TEMP: shamefully-hoist=true is a workaround for React Native Metro resolution issues.
# Long-term goal: fix package imports so hoisting is not required, then remove this flag.
shamefully-hoist=true

# Copy packages instead of linking from the store to reduce cross-filesystem issues
package-import-method=copy

# TEMP: strict-peer-dependencies=false suppresses peer dependency warnings during install.
# Long-term goal: resolve all peer dependency conflicts and enable strict mode for safety.
strict-peer-dependencies=false
