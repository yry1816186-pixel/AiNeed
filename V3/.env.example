# ============================================
# AiNeed V3 - Production Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# ---------- Database ----------
DATABASE_URL=postgresql://aineed:CHANGE_ME@localhost:5432/aineed_v3
POSTGRES_PASSWORD=CHANGE_ME

# ---------- Redis ----------
REDIS_URL=redis://:CHANGE_ME@localhost:6379/0
REDIS_PASSWORD=CHANGE_ME

# ---------- Qdrant ----------
QDRANT_URL=http://localhost:6333

# ---------- Neo4j ----------
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME

# ---------- Elasticsearch ----------
ELASTICSEARCH_URL=http://localhost:9200

# ---------- JWT ----------
JWT_SECRET=CHANGE_ME_TO_512_BIT_RANDOM_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------- MinIO ----------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=aineed

# ---------- AI Services ----------
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_MODEL=glm-5
DEEPSEEK_API_KEY=your-deepseek-api-key

# ---------- SMS ----------
SMS_PROVIDER=aliyun
ALIYUN_SMS_ACCESS_KEY=your-access-key
ALIYUN_SMS_SECRET_KEY=your-secret-key
ALIYUN_SMS_SIGN_NAME=AiNeed
ALIYUN_SMS_TEMPLATE_CODE=SMS_123456

# ---------- Payment ----------
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=
WECHAT_PAY_CERT_PATH=
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
PAYMENT_CALLBACK_URL=http://localhost:3001/api/v1/payment/callback

# ---------- ML Services ----------
EMBEDDING_SERVICE_URL=http://localhost:8003
BODY_ANALYSIS_URL=http://localhost:8004

# ---------- Outfit Image Generation ----------
OUTFIT_IMAGE_API_PROVIDER=zhipu
OUTFIT_IMAGE_API_KEY=your-zhipu-api-key
OUTFIT_IMAGE_API_URL=https://open.bigmodel.cn/api/paas/v4/images/generations

# ---------- POD ----------
POD_PROVIDER=eprolo
POD_API_KEY=your-eprolo-api-key
POD_API_URL=https://api.eprolo.com

# ---------- App ----------
APP_PORT=3001
APP_ENV=production
CORS_ORIGIN=https://aineed.com

# ---------- CDN ----------
CDN_BASE_URL=https://cdn.aineed.com

# ---------- Rate Limit ----------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ---------- Monitoring ----------
SENTRY_DSN=
