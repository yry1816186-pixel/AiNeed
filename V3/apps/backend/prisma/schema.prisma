generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone        String?   @unique
  email        String?   @unique
  passwordHash String?   @map("password_hash")
  nickname     String?
  avatarUrl    String?   @map("avatar_url")
  gender       String?
  birthYear    Int?      @map("birth_year")
  height       Int?
  weight       Int?
  bodyType     String?   @map("body_type")
  colorSeason  String?   @map("color_season")
  role         String    @default("user")
  language     String    @default("zh")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  bodyProfile           BodyProfile?
  stylePreferences      UserStylePreference[]
  outfits               Outfit[]
  wardrobeItems         WardrobeItem[]
  favorites             Favorite[]
  chatSessions          ChatSession[]
  tryonResults          TryonResult[]
  interactions          UserInteraction[]
  communityPosts        CommunityPost[]
  postComments          PostComment[]
  followerRelations     UserFollow[]       @relation("UserFollowers")
  followingRelations    UserFollow[]       @relation("UserFollowing")
  chatRoomParticipants  ChatRoomParticipant[]
  sentMessages          DirectMessage[]    @relation("DirectMessageSender")
  notifications         Notification[]
  userAvatars           UserAvatar[]
  customDesigns         CustomDesign[]
  customOrders          CustomOrder[]
  bespokeOrders         BespokeOrder[]
  bespokeOrdersAssigned BespokeOrder[]     @relation("BespokeAssignedStylist")
  bespokeStudios        BespokeStudio[]
  bespokeMessages       BespokeMessage[]
  bespokeReviews        BespokeReview[]
  outfitImages          OutfitImage[]
  designLikes           DesignLike[]
  designReports         DesignReport[]     @relation("DesignReporter")
  designReportsReviewed DesignReport[]     @relation("DesignReviewer")

  @@map("users")
}

model BodyProfile {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  bodyType       String?  @map("body_type")
  colorSeason    String?  @map("color_season")
  measurements   Json?
  analysisResult Json?    @map("analysis_result")
  sourceImageUrl String?  @map("source_image_url")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("body_profiles")
}

model UserStylePreference {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  styleTags       String[] @map("style_tags")
  occasionTags    String[] @map("occasion_tags")
  colorPreferences String[] @map("color_preferences")
  budgetRange     String?  @map("budget_range")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_style_preferences")
}

model Category {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  nameEn    String?    @map("name_en")
  slug      String     @unique
  parentId  String?    @map("parent_id") @db.Uuid
  sortOrder Int        @default(0) @map("sort_order")

  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  clothingItems ClothingItem[]

  @@map("categories")
}

model Brand {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  logoUrl     String? @map("logo_url")
  description String?

  clothingItems ClothingItem[]

  @@map("brands")
}

model ClothingItem {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  brandId       String?   @map("brand_id") @db.Uuid
  categoryId    String?   @map("category_id") @db.Uuid
  name          String
  description   String?
  price         Decimal?  @db.Decimal(10, 2)
  originalPrice Decimal?  @map("original_price") @db.Decimal(10, 2)
  currency      String    @default("CNY")
  gender        String?
  seasons       String[]
  occasions     String[]
  styleTags     String[]  @map("style_tags")
  colors        String[]
  materials     String[]
  fitType       String?   @map("fit_type")
  imageUrls     String[]  @map("image_urls")
  sourceUrl     String?   @map("source_url")
  purchaseUrl   String?   @map("purchase_url")
  sourceName    String?   @map("source_name")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  brand       Brand?          @relation(fields: [brandId], references: [id])
  category    Category?       @relation(fields: [categoryId], references: [id])
  outfitItems OutfitItem[]
  interactions UserInteraction[]
  tryonResults TryonResult[]
  wardrobeItems WardrobeItem[]

  @@index([categoryId])
  @@index([brandId])
  @@index([gender])
  @@map("clothing_items")
}

model Outfit {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String?      @map("user_id") @db.Uuid
  name           String?
  description    String?
  occasion       String?
  season         String?
  styleTags      String[]     @map("style_tags")
  isPublic       Boolean      @default(false) @map("is_public")
  likesCount     Int          @default(0) @map("likes_count")
  commentsCount  Int          @default(0) @map("comments_count")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz

  user           User?        @relation(fields: [userId], references: [id])
  items          OutfitItem[]
  communityPosts CommunityPost[]

  @@map("outfits")
}

model OutfitItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outfitId    String  @map("outfit_id") @db.Uuid
  clothingId  String  @map("clothing_id") @db.Uuid
  slot        String
  sortOrder   Int     @default(0) @map("sort_order")

  outfit      Outfit       @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  clothingItem ClothingItem @relation(fields: [clothingId], references: [id])

  @@map("outfit_items")
}

model ChatSession {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String?
  context   Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  role      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

model TryonResult {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  clothingId     String   @map("clothing_id") @db.Uuid
  sourceImageUrl String   @map("source_image_url")
  resultImageUrl String?  @map("result_image_url")
  provider       String?
  status         String   @default("pending")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  clothingItem  ClothingItem @relation(fields: [clothingId], references: [id])

  @@index([userId, createdAt])
  @@map("tryon_results")
}

model UserInteraction {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  clothingId      String   @map("clothing_id") @db.Uuid
  interactionType String   @map("interaction_type")
  durationMs      Int?     @map("duration_ms")
  context         Json?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  clothingItem ClothingItem @relation(fields: [clothingId], references: [id])

  @@index([userId, createdAt])
  @@map("user_interactions")
}

model WardrobeItem {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  clothingId  String?  @map("clothing_id") @db.Uuid
  customName  String?  @map("custom_name")
  imageUrl    String?  @map("image_url")
  category    String?
  color       String?
  brand       String?
  notes       String?
  addedAt     DateTime @default(now()) @map("added_at") @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  clothingItem ClothingItem? @relation(fields: [clothingId], references: [id])

  @@map("wardrobe_items")
}

model Favorite {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  targetType String   @map("target_type")
  targetId   String   @map("target_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
  @@map("favorites")
}

model StyleRule {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category       String
  ruleType       String  @map("rule_type")
  condition      Json
  recommendation String
  priority       Int     @default(0)
  isActive       Boolean @default(true) @map("is_active")

  @@map("style_rules")
}

model CommunityPost {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  title         String?
  content       String
  imageUrls     String[]  @map("image_urls")
  tags          String[]
  outfitId      String?   @map("outfit_id") @db.Uuid
  likesCount    Int       @default(0) @map("likes_count")
  commentsCount Int       @default(0) @map("comments_count")
  sharesCount   Int       @default(0) @map("shares_count")
  isFeatured    Boolean   @default(false) @map("is_featured")
  status        String    @default("published")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfit   Outfit?        @relation(fields: [outfitId], references: [id])
  comments PostComment[]

  @@index([userId, createdAt])
  @@index([isFeatured, createdAt])
  @@index([status])
  @@map("community_posts")
}

model PostComment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId     String   @map("post_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  parentId   String?  @map("parent_id") @db.Uuid
  content    String
  likesCount Int      @default(0) @map("likes_count")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  post   PostComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies PostComment[] @relation("CommentReplies")
  communityPost CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("post_comments")
}

model UserFollow {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  followerId  String   @map("follower_id") @db.Uuid
  followingId String   @map("following_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  follower  User @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@map("user_follows")
}

model ChatRoom {
  id         String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt  DateTime                 @default(now()) @map("created_at") @db.Timestamptz

  participants ChatRoomParticipant[]
  messages     DirectMessage[]

  @@map("chat_rooms")
}

model ChatRoomParticipant {
  roomId   String   @map("room_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
  @@index([userId])
  @@index([roomId])
  @@map("chat_room_participants")
}

model DirectMessage {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId      String   @map("room_id") @db.Uuid
  senderId    String   @map("sender_id") @db.Uuid
  content     String
  messageType String   @default("text") @map("message_type")
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User     @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@map("direct_messages")
}

model Notification {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  type          String
  title         String?
  content       String?
  referenceId   String?  @map("reference_id") @db.Uuid
  referenceType String?  @map("reference_type")
  isRead        Boolean  @default(false) @map("is_read")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("notifications")
}

model AvatarTemplate {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  gender            String
  thumbnailUrl      String? @map("thumbnail_url")
  drawingConfig     Json    @map("drawing_config")
  parameters        Json
  defaultClothingMap Json?  @map("default_clothing_map")
  isActive          Boolean @default(true) @map("is_active")
  sortOrder         Int     @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  userAvatars UserAvatar[]

  @@map("avatar_templates")
}

model UserAvatar {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  templateId    String   @map("template_id") @db.Uuid
  avatarParams  Json     @map("avatar_params")
  clothingMap   Json?    @map("clothing_map")
  thumbnailUrl  String?  @map("thumbnail_url")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  template AvatarTemplate @relation(fields: [templateId], references: [id])

  @@index([userId])
  @@map("user_avatars")
}

model CustomDesign {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  name             String
  designData       Json      @map("design_data")
  patternImageUrl  String?   @map("pattern_image_url")
  previewImageUrl  String?   @map("preview_image_url")
  productType      String    @map("product_type")
  productTemplateId String?  @map("product_template_id") @db.Uuid
  isPublic         Boolean   @default(false) @map("is_public")
  price            Int?
  likesCount       Int       @default(0) @map("likes_count")
  purchasesCount   Int       @default(0) @map("purchases_count")
  tags             String[]
  status           String    @default("draft")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  customOrders CustomOrder[]
  designLikes  DesignLike[]
  designReports DesignReport[]

  @@index([userId, createdAt])
  @@index([isPublic, createdAt])
  @@index([productType])
  @@map("custom_designs")
}

model CustomOrder {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  designId        String   @map("design_id") @db.Uuid
  productType     String   @map("product_type")
  material        String
  size            String
  quantity        Int      @default(1)
  unitPrice       Int      @map("unit_price")
  totalPrice      Int      @map("total_price")
  status          String   @default("pending")
  podOrderId      String?  @map("pod_order_id")
  trackingNumber  String?  @map("tracking_number")
  shippingAddress Json     @map("shipping_address")
  paymentInfo     Json?    @map("payment_info")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  design CustomDesign @relation(fields: [designId], references: [id])

  @@index([userId, createdAt])
  @@index([status])
  @@map("custom_orders")
}

model ProductTemplate {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productType     String  @map("product_type")
  material        String
  baseCost        Int     @map("base_cost")
  suggestedPrice  Int     @map("suggested_price")
  uvMapUrl        String  @map("uv_map_url")
  previewModelUrl String? @map("preview_model_url")
  availableSizes  String[] @map("available_sizes")
  printArea       Json    @map("print_area")
  podProvider     String? @map("pod_provider")
  podProductId    String? @map("pod_product_id")
  isActive        Boolean @default(true) @map("is_active")

  @@index([productType, material])
  @@map("product_templates")
}

model DesignLike {
  userId    String   @map("user_id") @db.Uuid
  designId  String   @map("design_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  design CustomDesign @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@id([userId, designId])
  @@map("design_likes")
}

model DesignReport {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporterId   String   @map("reporter_id") @db.Uuid
  designId     String   @map("design_id") @db.Uuid
  reason       String
  description  String?
  reviewResult Json?    @map("review_result")
  status       String   @default("pending")
  reviewedBy   String?  @map("reviewed_by") @db.Uuid
  reviewedAt   DateTime? @map("reviewed_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  reporter   User         @relation("DesignReporter", fields: [reporterId], references: [id])
  design     CustomDesign @relation(fields: [designId], references: [id])
  reviewer   User?        @relation("DesignReviewer", fields: [reviewedBy], references: [id])

  @@index([designId])
  @@index([status])
  @@map("design_reports")
}

model BespokeStudio {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  name           String
  slug           String    @unique
  logoUrl        String?   @map("logo_url")
  coverImageUrl  String?   @map("cover_image_url")
  description    String?
  city           String?
  address        String?
  specialties    String[]
  serviceTypes   String[]  @map("service_types")
  priceRange     String?   @map("price_range")
  portfolioImages String[] @map("portfolio_images")
  rating         Decimal   @default(0) @db.Decimal(3, 2)
  reviewCount    Int       @default(0) @map("review_count")
  orderCount     Int       @default(0) @map("order_count")
  isVerified     Boolean   @default(false) @map("is_verified")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user          User           @relation(fields: [userId], references: [id])
  bespokeOrders BespokeOrder[]
  bespokeQuotes BespokeQuote[]
  bespokeReviews BespokeReview[]

  @@index([city])
  @@index([isVerified, rating])
  @@map("bespoke_studios")
}

model BespokeOrder {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  studioId         String    @map("studio_id") @db.Uuid
  status           String    @default("submitted")
  title            String?
  description      String
  referenceImages  String[]  @map("reference_images")
  budgetRange      String?   @map("budget_range")
  deadline         DateTime? @db.Date
  measurements     Json?
  assignedStylistId String?  @map("assigned_stylist_id") @db.Uuid
  statusHistory    Json      @default("[]") @map("status_history")
  completedAt      DateTime? @map("completed_at") @db.Timestamptz
  cancelledAt      DateTime? @map("cancelled_at") @db.Timestamptz
  cancelReason     String?   @map("cancel_reason")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  studio         BespokeStudio   @relation(fields: [studioId], references: [id])
  assignedStylist User?          @relation("BespokeAssignedStylist", fields: [assignedStylistId], references: [id])
  bespokeMessages BespokeMessage[]
  bespokeQuotes  BespokeQuote[]
  bespokeReview  BespokeReview?

  @@index([userId, createdAt])
  @@index([studioId, status])
  @@index([status])
  @@map("bespoke_orders")
}

model BespokeMessage {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String   @map("order_id") @db.Uuid
  senderId    String   @map("sender_id") @db.Uuid
  content     String
  messageType String   @default("text") @map("message_type")
  attachments String[]
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  order  BespokeOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sender User         @relation(fields: [senderId], references: [id])

  @@index([orderId, createdAt])
  @@map("bespoke_messages")
}

model BespokeQuote {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId       String    @map("order_id") @db.Uuid
  studioId      String    @map("studio_id") @db.Uuid
  totalPrice    Int       @map("total_price")
  items         Json
  estimatedDays Int?      @map("estimated_days")
  validUntil    DateTime? @map("valid_until") @db.Timestamptz
  notes         String?
  status        String    @default("pending")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  order  BespokeOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  studio BespokeStudio @relation(fields: [studioId], references: [id])

  @@index([orderId, createdAt])
  @@map("bespoke_quotes")
}

model BespokeReview {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String   @map("order_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  studioId    String   @map("studio_id") @db.Uuid
  rating      Int
  content     String?
  images      String[]
  isAnonymous Boolean  @default(false) @map("is_anonymous")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  order  BespokeOrder  @relation(fields: [orderId], references: [id])
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  studio BespokeStudio @relation(fields: [studioId], references: [id])

  @@unique([orderId])
  @@index([studioId, createdAt])
  @@map("bespoke_reviews")
}

model OutfitImage {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  outfitData Json     @map("outfit_data")
  prompt     String?
  imageUrl   String?  @map("image_url")
  status     String   @default("pending")
  cost       Int      @default(0)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
  @@map("outfit_images")
}
