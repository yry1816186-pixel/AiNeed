{
  "name": "aineed-v3",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:backend": "cd apps/backend && npm run start:dev",
    "dev:mobile": "cd apps/mobile && npx expo start",
    "build:backend": "cd apps/backend && npm run build",
    "build:mobile": "cd apps/mobile && npx expo export",
    "test:backend": "cd apps/backend && npm run test",
    "test:mobile": "cd apps/mobile && npm run test",
    "lint": "npm run lint --workspaces",
    "lint:fix": "npm run lint --workspaces -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces",
    "prepare": "husky",
    "db:push": "cd apps/backend && npx prisma db push",
    "db:migrate": "cd apps/backend && npx prisma migrate dev",
    "db:seed": "cd apps/backend && npx tsx prisma/seed.ts",
    "docker:up": "cd docker && docker-compose up -d",
    "docker:down": "cd docker && docker-compose down"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@react-native-community/netinfo": "^12.0.1",
    "expo-notifications": "~0.32.16"
  },
  "pnpm": {
    "overrides": {
      "lodash": "^4.18.0",
      "axios": "^1.15.0",
      "path-to-regexp": "^8.4.0",
      "picomatch": "^4.0.4",
      "@nestjs/core": "^11.1.18",
      "@nestjs/common": "^11.1.18",
      "@nestjs/platform-express": "^11.1.18",
      "nodemailer": "^8.0.5",
      "@hono/node-server": "^1.19.13"
    }
  }
}
